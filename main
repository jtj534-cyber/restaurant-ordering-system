import json
from datetime import datetime

# Store all available menu items as dictionaries (id, name, price)
menu = [
    {"id": 1, "name": "Burger", "price": 6.50},
    {"id": 2, "name": "Pizza", "price": 8.00},
    {"id": 3, "name": "Pasta", "price": 7.25},
    {"id": 4, "name": "Fries", "price": 3.00},
    {"id": 5, "name": "Drink", "price": 2.00}
]

# Store all items selected by the user
basket = []


def display_menu():
    """Display all menu items to the user."""
    print("\n--- MENU ---")
    for item in menu:
        # Print each menu item with its id and price
        print(f"{item['id']}. {item['name']} - £{item['price']:.2f}")


def find_item_by_id(item_id):
    """Search for a menu item using its ID and return it."""
    for item in menu:
        if item["id"] == item_id:
            return item  # Return matching item
    return None  # Return None if item is not found


def add_to_basket():
    """Add an item to the basket or update quantity if it already exists."""
    try:
        item_id = int(input("Enter item ID to add: "))
        item = find_item_by_id(item_id)

        # Validate item ID
        if item is None:
            print("Invalid item ID.")
            return

        quantity = int(input("Enter quantity: "))

        # Ensure quantity is positive
        if quantity <= 0:
            print("Quantity must be greater than 0.")
            return

        # Check if item already exists in the basket
        for basket_item in basket:
            if basket_item["name"] == item["name"]:
                # Increase quantity instead of adding duplicate item
                basket_item["quantity"] += quantity
                print(f"Updated quantity of {item['name']} to {basket_item['quantity']}.")
                return

        # Add new item if not already in basket
        basket.append({
            "name": item["name"],
            "price": item["price"],
            "quantity": quantity
        })

        print(f"{item['name']} added to basket.")

    except ValueError:
        # Handle invalid input types
        print("Please enter valid numbers only.")


def view_basket():
    """Display all items in the basket with cost breakdown."""
    print("\n--- BASKET ---")

    # Check if basket is empty
    if not basket:
        print("Your basket is empty.")
        return

    # Calculate totals
    subtotal, tax, total = calculate_total()

    # Display basket contents
    for index, item in enumerate(basket, start=1):
        item_total = item["price"] * item["quantity"]
        print(f"{index}. {item['name']} x{item['quantity']} = £{item_total:.2f}")

    # Display summary values
    print(f"Subtotal: £{subtotal:.2f}")
    print(f"Tax (10%): £{tax:.2f}")
    print(f"Total: £{total:.2f}")


def remove_from_basket():
    """Remove an item from the basket using its position."""
    view_basket()

    # Stop if basket is empty
    if not basket:
        return

    try:
        item_number = int(input("Enter basket item number to remove: "))

        # Validate selected index
        if 1 <= item_number <= len(basket):
            removed_item = basket.pop(item_number - 1)
            print(f"{removed_item['name']} removed from basket.")
        else:
            print("Invalid basket number.")

    except ValueError:
        print("Please enter a valid number.")


def calculate_total():
    """Calculate subtotal, tax, and total cost."""
    subtotal = 0

    # Sum all item costs
    for item in basket:
        subtotal += item["price"] * item["quantity"]

    # Apply 10% tax and round values to 2 decimal places
    tax = round(subtotal * 0.10, 2)
    total = round(subtotal + tax, 2)

    return subtotal, tax, total


def sort_menu_by_price():
    """Display menu items sorted by price."""
    # Sort menu based on price (ascending)
    sorted_menu = sorted(menu, key=lambda item: item["price"])

    print("\n--- MENU SORTED BY PRICE ---")
    for item in sorted_menu:
        print(f"{item['id']}. {item['name']} - £{item['price']:.2f}")


def save_order(total_paid, change):
    """Save completed order details to the JSON file."""
    subtotal, tax, total = calculate_total()

    # Create a dictionary containing all order information
    order_data = {
        "date": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "items": basket.copy(),
        "subtotal": subtotal,
        "tax": tax,
        "total": total,
        "paid": total_paid,
        "change": change
    }

    try:
        # Read existing orders from the file
        try:
            with open("orders.json", "r", encoding="utf-8") as file:
                orders = json.load(file)

                # Ensure the file contains a list
                if not isinstance(orders, list):
                    orders = []

        except (FileNotFoundError, json.JSONDecodeError):
            # Start with an empty list if the file does not exist or is invalid
            orders = []

        # Add the new order to the list
        orders.append(order_data)

        # Write each order on one line while keeping the file as valid JSON
        with open("orders.json", "w", encoding="utf-8") as file:
            file.write("[\n")
            for index, order in enumerate(orders):
                json.dump(order, file, separators=(",", ":"))
                if index < len(orders) - 1:
                    file.write(",\n")
                else:
                    file.write("\n")
            file.write("]")

    except Exception as error:
        print("Error saving order:", error)


def checkout():
    """Process payment, save order, and clear basket."""
    if not basket:
        print("Basket is empty. Add items first.")
        return

    subtotal, tax, total = calculate_total()

    # Display cost breakdown
    print(f"\nSubtotal: £{subtotal:.2f}")
    print(f"Tax (10%): £{tax:.2f}")
    print(f"Total: £{total:.2f}")

    try:
        payment = float(input("Enter payment amount: "))

        # Check if payment is sufficient
        if payment < total:
            print("Not enough payment.")
            return

        # Calculate change and round it to 2 decimal places
        change = round(payment - total, 2)
        print(f"Payment accepted. Change: £{change:.2f}")

        # Save order and reset basket
        save_order(payment, change)
        basket.clear()

        print("Order saved successfully.")

    except ValueError:
        print("Please enter a valid payment amount.")


def daily_sales_report():
    """Read saved orders and display a sales summary."""
    try:
        # Load all saved orders from the JSON file
        with open("orders.json", "r", encoding="utf-8") as file:
            orders = json.load(file)

        # Check if the file contains any orders
        if not orders:
            print("No sales data found yet.")
            return

        total_sales = 0
        order_count = 0

        # Calculate the number of orders and total sales value
        for order in orders:
            total_sales += order["total"]
            order_count += 1

        print("\n--- DAILY SALES REPORT ---")
        print(f"Orders today: {order_count}")
        print(f"Total sales: £{total_sales:.2f}")

    except FileNotFoundError:
        print("No sales data found yet.")
    except json.JSONDecodeError:
        print("The sales file is not in the correct format.")
    except Exception as error:
        print("Error reading sales report:", error)


def main():
    """Main loop to handle user interaction."""
    while True:
        print("\n=== RESTAURANT ORDERING SYSTEM ===")
        print("1. Display menu")
        print("2. Add to basket")
        print("3. View basket")
        print("4. Remove from basket")
        print("5. Sort menu by price")
        print("6. Checkout")
        print("7. Daily sales report")
        print("8. Exit")

        choice = input("Choose an option: ")

        # Execute function based on user input
        if choice == "1":
            display_menu()
        elif choice == "2":
            add_to_basket()
        elif choice == "3":
            view_basket()
        elif choice == "4":
            remove_from_basket()
        elif choice == "5":
            sort_menu_by_price()
        elif choice == "6":
            checkout()
        elif choice == "7":
            daily_sales_report()
        elif choice == "8":
            print("Goodbye.")
            break
        else:
            print("Invalid choice. Please try again.")


# Start the program
main()
